  "legal": {
    "backHome": "← Back to home",
    "privacyTitle": "Privacy policy",
    "privacyBody": [
      "This CFRM Hub prototype follows data minimisation: only information needed to collect, process and track feedback is requested.",
      "On the public form, most fields are optional. For staff, access is role-based (least privilege). Sensitive actions may be logged.",
      "For any request regarding your personal data, contact the organisation operating this instance."
    ],
    "termsTitle": "Terms of use",
    "termsBody": [
      "CFRM Hub is an accountability tool for affected populations and authorised staff. Fair use of the public site is required: no unlawful or defamatory content, and nothing that could endanger people’s safety.",
      "The team workspace (sign-in) is for administrator-created accounts only. Misuse may lead to account suspension.",
      "Copy and flows may change across prototype versions; a pilot or production rollout may add specific terms."
    ],
    "accessibilityTitle": "Accessibility",
    "accessibilityBody": [
      "We aim for readable UI, usable contrast in light and dark themes, and keyboard navigation on main paths (home, public form, information pages).",
      "If you hit a barrier (screen reader, contrast, unclear wording), tell the project team so we can prioritise fixes where feasible."
    ],
    "helpTitle": "Help",
    "helpBody": [
      "To send a message without an account: from the home page, use “Submit feedback” and follow the form steps.",
      "For authorised staff: sign in via “Team portal” / “Sign in” with the email and password provided by your administrator.",
      "For technical questions or account requests, contact your organisation’s CFRM Hub administrator."
    ]
  },
